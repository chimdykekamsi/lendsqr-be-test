{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    /* Environment */
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    /* Type Safety */
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    /* Paths */
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    /* Fix TS 6 warnings */
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}